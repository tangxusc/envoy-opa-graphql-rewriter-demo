        "graphqlSchema": "schema {\n  query: Query\n  mutation: Mutation\n  subscription: Subscription\n}\n\ntype Employee {\n  id: ID!\n  name: String!\n  salary: Int!\n  todos: [Todo!]!\n}\n\ntype Query {\n  employeeByID(id: ID!): Employee\n  employees: [Employee!]!\n  employeeTodos(employeeID: ID!): [Todo!]!\n  todoByID(id: ID!): Todo\n}\n\ntype Mutation {\n  updateEmployee(id: ID!, name: String, salary: Int): Employee!\n  createTodo(employeeID: ID!, content: String!): Todo!\n  updateTodo(id: ID!, content: String!): Todo!\n  deleteTodo(id: ID!): Todo!\n}\n\ntype Subscription {\n  employeeUpdated(id: ID): Employee!\n  employeeTodoChanged(employeeID: ID!): Employee!\n}\n\ntype Todo {\n  id: ID!\n  employeeID: ID!\n  content: String!\n  updatedAt: String!\n  deleted: Boolean!\n}\n\nscalar openfed__Any",
        "stringStorage": {
            "05ebe65ae05f696ae76fd800024cc257dffc175e": "schema {\n  query: Query\n  mutation: Mutation\n  subscription: Subscription\n}\n\ndirective @key(fields: openfed__FieldSet!, resolvable: Boolean = true) repeatable on INTERFACE | OBJECT\n\ndirective @link(as: String, for: link__Purpose, import: [link__Import], url: String!) repeatable on SCHEMA\n\ntype Employee @key(fields: \"id\") {\n  id: ID!\n  name: String!\n  salary: Int!\n}\n\ntype Mutation {\n  updateEmployee(id: ID!, name: String, salary: Int): Employee!\n}\n\ntype Query {\n  employeeByID(id: ID!): Employee\n  employees: [Employee!]!\n}\n\ntype Subscription {\n  employeeUpdated(id: ID): Employee!\n}\n\nscalar link__Import\n\nenum link__Purpose {\n  EXECUTION\n  SECURITY\n}\n\nscalar openfed__FieldSet",
            "e61a01978d9a8ed2125c7f0bd296ad4da324748d": "schema {\n  query: Query\n  mutation: Mutation\n}\n\ndirective @external on FIELD_DEFINITION | OBJECT\n\ndirective @key(fields: openfed__FieldSet!, resolvable: Boolean = true) repeatable on INTERFACE | OBJECT\n\ndirective @link(as: String, for: link__Purpose, import: [link__Import], url: String!) repeatable on SCHEMA\n\ntype Employee @key(fields: \"id\") {\n  id: ID! @external\n  todos: [Todo!]!\n}\n\ntype Mutation {\n  createTodo(content: String!, employeeID: ID!): Todo!\n  deleteTodo(id: ID!): Todo!\n  updateTodo(content: String!, id: ID!): Todo!\n}\n\ntype Query {\n  employeeTodos(employeeID: ID!): [Todo!]!\n  todoByID(id: ID!): Todo\n}\n\ntype Todo @key(fields: \"id\") {\n  content: String!\n  deleted: Boolean!\n  employeeID: ID!\n  id: ID!\n  updatedAt: String!\n}\n\nscalar link__Import\n\nenum link__Purpose {\n  EXECUTION\n  SECURITY\n}\n\nscalar openfed__FieldSet",
            "ab9b664bf7577baaa8dcac0a56cecc89275f298e": "schema {\n  subscription: Subscription\n}\n\ndirective @edfs__kafkaSubscribe(providerId: String! = \"default\", topics: [String!]!) on FIELD_DEFINITION\n\ndirective @external on FIELD_DEFINITION | OBJECT\n\ndirective @key(fields: openfed__FieldSet!, resolvable: Boolean = true) repeatable on INTERFACE | OBJECT\n\ndirective @link(as: String, for: link__Purpose, import: [link__Import], url: String!) repeatable on SCHEMA\n\ndirective @openfed__subscriptionFilter(condition: openfed__SubscriptionFilterCondition!) on FIELD_DEFINITION\n\ntype Employee @key(fields: \"id\", resolvable: false) {\n  id: ID! @external\n}\n\ntype Subscription {\n  employeeTodoChanged(employeeID: ID!): Employee! @edfs__kafkaSubscribe(topics: [\"employee.todo.events\"], providerId: \"demo-kafka\") @openfed__subscriptionFilter(condition: {IN: {fieldPath: \"id\", values: [\"{{ args.employeeID }}\"]}})\n}\n\nscalar link__Import\n\nenum link__Purpose {\n  EXECUTION\n  SECURITY\n}\n\nscalar openfed__Any\n\nscalar openfed__FieldSet\n\ninput openfed__SubscriptionFieldCondition {\n  fieldPath: String!\n  values: [openfed__Any!]!\n}\n\ninput openfed__SubscriptionFilterCondition {\n  AND: [openfed__SubscriptionFilterCondition!]\n  IN: openfed__SubscriptionFieldCondition\n  NOT: openfed__SubscriptionFilterCondition\n  NOT_IN: openfed__SubscriptionFieldCondition\n  OR: [openfed__SubscriptionFilterCondition!]\n}\n\nscalar openfed__SubscriptionFilterValue"
