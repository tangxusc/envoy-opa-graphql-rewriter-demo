extend schema
  @link(url: "https://specs.apollo.dev/federation/v2.3", import: ["@key"])

type Employee @key(fields: "id") {
  id: ID!
  name: String!
  salary: Int!
}

type Query {
  employeeByID(id: ID!): Employee
  employees: [Employee!]!
}

type Mutation {
  updateEmployee(id: ID!, name: String, salary: Int): Employee!
}

type Subscription {
  employeeUpdated(id: ID): Employee!
}
